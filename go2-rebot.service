[Unit]
Description=Go2 ReBot — Xbox controller bridge for Unitree Go2
After=bluetooth.target multi-user.target NetworkManager.service
Wants=bluetooth.target NetworkManager.service

[Service]
Type=simple
User=goofy-go2
Group=goofy-go2
WorkingDirectory=/home/goofy-go2/projects/re-bot/go2-rebot
ExecStart=/home/goofy-go2/projects/re-bot/go2-rebot/headless-start.sh
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
